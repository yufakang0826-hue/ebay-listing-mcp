# 公司内部模板
# 每个员工在自己的电脑上复制为 .env

EBAY_API_ENV=production
EBAY_CLIENT_ID=company-client-id
EBAY_CLIENT_SECRET=company-client-secret
EBAY_REDIRECT_URI=company-ru-name
EBAY_MARKETPLACE_ID=EBAY_US
EBAY_CONTENT_LANGUAGE=en-US

# 只读员工保持关闭生产写入
EBAY_ALLOW_PRODUCTION_WRITES=false

# OAuth 完成后，token 会自动写回本地 .env
# 不要提交真实值
EBAY_USER_ACCESS_TOKEN=
EBAY_USER_ACCESS_TOKEN_EXPIRY=
EBAY_USER_REFRESH_TOKEN=
EBAY_USER_REFRESH_TOKEN_EXPIRY=
